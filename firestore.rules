rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPER FUNCTIONS ──────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isRoomMember(roomId) {
      return exists(/databases/$(database)/documents/rooms/$(roomId)/participants/$(request.auth.uid));
    }

    function isRoomAdmin(roomId) {
      return get(/databases/$(database)/documents/rooms/$(roomId)).data.createdBy == request.auth.uid;
    }

    function roomIsActive(roomId) {
      let room = get(/databases/$(database)/documents/rooms/$(roomId));
      return room.data.status == 'active' && room.data.expiresAt > request.time;
    }

    function notExpired() {
      return resource.data.expiresAt > request.time;
    }

    // ─── USERS ───────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAuthenticated() && isOwner(userId);
      allow delete: if isAuthenticated() && isOwner(userId);
    }

    // ─── ROOMS ───────────────────────────────────────────────
    match /rooms/{roomId} {
      // Anyone authenticated can read room metadata (to check if it exists)
      allow read: if isAuthenticated();

      // Only authenticated users can create rooms
      allow create: if isAuthenticated()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status == 'active'
        && request.resource.data.expiresAt is timestamp
        && request.resource.data.expiresAt > request.time;

      // Members can update participant count, admin can update status
      allow update: if isAuthenticated() && (
        isRoomAdmin(roomId) ||
        (isRoomMember(roomId) && roomIsActive(roomId))
      );

      // Only admin can delete
      allow delete: if isAuthenticated() && isRoomAdmin(roomId);

      // ─── MESSAGES ──────────────────────────────────────────
      match /messages/{messageId} {
        allow read: if isAuthenticated() && isRoomMember(roomId);
        allow create: if isAuthenticated()
          && isRoomMember(roomId)
          && roomIsActive(roomId)
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.encryptedContent is string
          && request.resource.data.iv is string;
        allow update, delete: if false; // Messages are immutable
      }

      // ─── PARTICIPANTS ───────────────────────────────────────
      match /participants/{participantId} {
        allow read: if isAuthenticated() && isRoomMember(roomId);
        allow create: if isAuthenticated()
          && isOwner(participantId)
          && roomIsActive(roomId);
        allow update: if isAuthenticated()
          && (isOwner(participantId) || isRoomAdmin(roomId))
          && roomIsActive(roomId);
        allow delete: if isAuthenticated() && isRoomAdmin(roomId);
      }
    }

    // ─── UPLOADS ────────────────────────────────────────────
    match /uploads/{uploadId} {
      allow read: if isAuthenticated() && (
        resource.data.uploadedBy == request.auth.uid ||
        isRoomMember(resource.data.roomId)
      );
      allow create: if isAuthenticated()
        && request.resource.data.uploadedBy == request.auth.uid
        && isRoomMember(request.resource.data.roomId);
      allow update: if isAuthenticated()
        && resource.data.uploadedBy == request.auth.uid;
      allow delete: if isAuthenticated()
        && (resource.data.uploadedBy == request.auth.uid ||
            isRoomAdmin(resource.data.roomId));
    }

    // ─── BLOCK EVERYTHING ELSE ──────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
